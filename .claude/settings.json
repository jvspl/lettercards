{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "GH_CONFIG_DIR": "~/.config/gh-claude",
    "GIT_CONFIG_COUNT": "1",
    "GIT_CONFIG_KEY_0": "credential.https://github.com.helper",
    "GIT_CONFIG_VALUE_0": "!f() { echo username=x-access-token; echo password=$GH_TOKEN; }; f"
  },
  "permissions": {
    "allow": [
      "Bash(gh issue view *)",
      "Bash(gh issue list *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr checks *)",
      "Bash(gh api user *)"
    ],
    "disableBypassPermissionsMode": "disable",
    "defaultMode": "plan"
  },
  "sandbox": {
    "enabled": true,
    "enableWeakerNetworkIsolation": true,
    "allowUnsandboxedCommands": false,
    "excludedCommands": ["git", "gh"],
    "ignoreViolations": {
      "git": [".git"]
    },
    "filesystem": {
      "allowWrite": [".", ".git"],
      "denyRead": ["~/"],
      "allowRead": [".", "~/.gitconfig", "~/.config/git", "~/.config/gh-claude"]
    },
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "api.anthropic.com"
      ]
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start-github-check.sh",
            "statusMessage": "Checking GitHub activity..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-settings-prewrite.sh",
            "statusMessage": "Checking settings file safety..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-bash-settings-write.sh",
            "statusMessage": "Checking for settings writes via Bash..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-settings-change.sh",
            "statusMessage": "Checking for settings file changes..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/auto-review-on-pr-create.sh",
            "statusMessage": "Checking if PR was just created..."
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/auto-rereview-on-push.sh",
            "statusMessage": "Checking for outstanding PR review findings..."
          }
        ]
      }
    ]
  }
}
